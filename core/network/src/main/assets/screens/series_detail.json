{
  "screenId": "series_detail",
  "dataSource": {
    "type": "remote",
    "request": {
      "method": "GET",
      "url": "https://www.omdbapi.com/?i={{seriesId}}&apikey=8170cd9d",
      "headers": {},
      "queryParams": {},
      "timeout": 10
    },
    "response": {
      "type": "object",
      "fieldMapping": {
        "id": "imdbID",
        "title": "Title",
        "year": "Year",
        "genre": "Genre",
        "posterURL": "Poster",
        "rating": "imdbRating",
        "runtime": "Runtime",
        "awards": "Awards",
        "plot": "Plot",
        "actors": "Actors",
        "writer": "Writer",
        "director": "Director",
        "totalSeasons": "totalSeasons"
      }
    }
  },
  "type": "scroll",
  "children": [
    {
      "id": "detailColumn",
      "type": "column",
      "accessibility": {
        "mergeDescendants": false
      },
      "style": {
        "padding": 16,
        "spacing": 14,
        "backgroundColor": "screenBackground"
      },
      "children": [
        {
          "id": "backBar",
          "type": "topBar",
          "accessibility": {
            "label": "Navigate back",
            "role": "button",
            "hint": "go back"
          },
          "props": {
            "leadingIcon": "back"
          },
          "style": {
            "padding": 0,
            "paddingTop": 4,
            "paddingBottom": 0
          },
          "action": {
            "type": "back"
          }
        },
        {
          "id": "detailHeader",
          "type": "header",
          "accessibility": {
            "label": "{{title}}, {{year}}, {{genre}}",
            "role": "header",
            "mergeDescendants": true
          },
          "titleTemplate": "{{title}}",
          "subtitleTemplate": "{{year}} • {{genre}}",
          "style": {
            "spacing": 4,
            "padding": 0,
            "paddingTop": 0,
            "paddingBottom": 4,
            "foregroundColor": "primaryText"
          }
        },
        {
          "id": "heroRow",
          "type": "row",
          "accessibility": {
            "label": "{{title}}, IMDb {{rating}}, Runtime {{runtime}}, Seasons {{totalSeasons}}",
            "mergeDescendants": true
          },
          "style": {
            "spacing": 16,
            "padding": 16,
            "backgroundColor": "cardBackground",
            "cornerRadius": 24
          },
          "children": [
            {
              "id": "detailPoster",
              "type": "image",
              "dataBinding": "posterURL",
              "accessibility": {
                "label": "{{title}} poster",
                "role": "image"
              },
              "style": {
                "frameWidth": 132,
                "frameHeight": 190,
                "cornerRadius": 18
              }
            },
            {
              "id": "heroMeta",
              "type": "column",
              "accessibility": {
                "mergeDescendants": true
              },
              "style": {
                "spacing": 10
              },
              "children": [
                {
                  "id": "ratingMetaRow",
                  "type": "row",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "spacing": 8
                  },
                  "children": [
                    {
                      "id": "detailRatingIcon",
                      "type": "icon",
                      "icon": "star.fill",
                      "accessibility": {
                        "importantForAccessibility": false
                      },
                      "style": {
                        "fontSize": 12,
                        "foregroundColor": "accent"
                      }
                    },
                    {
                      "id": "detailRating",
                      "type": "text",
                      "template": "IMDb {{rating}}",
                      "accessibility": {
                        "importantForAccessibility": false
                      },
                      "style": {
                        "fontSize": 15,
                        "fontWeight": "semibold",
                        "foregroundColor": "primaryText"
                      }
                    }
                  ]
                },
                {
                  "id": "runtime",
                  "type": "text",
                  "template": "Runtime: {{runtime}}",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "fontSize": 14,
                    "foregroundColor": "secondaryText"
                  }
                },
                {
                  "id": "seasons",
                  "type": "text",
                  "template": "Seasons: {{totalSeasons}}",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "fontSize": 14,
                    "foregroundColor": "secondaryText"
                  }
                },
                {
                  "id": "awards",
                  "type": "text",
                  "template": "Awards: {{awards}}",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "fontSize": 14,
                    "foregroundColor": "secondaryText",
                    "lineLimit": 3
                  },
                  "visibility": {
                    "dataBinding": "awards",
                    "isNotEmpty": true
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "plotSection",
          "type": "column",
          "accessibility": {
            "label": "Synopsis, {{plot}}",
            "mergeDescendants": true
          },
          "style": {
            "padding": 16,
            "spacing": 10,
            "backgroundColor": "surface",
            "cornerRadius": 22
          },
          "children": [
            {
              "id": "plotTitle",
              "type": "text",
              "text": "Synopsis",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 18,
                "fontWeight": "bold",
                "foregroundColor": "primaryText"
              }
            },
            {
              "id": "plotText",
              "type": "text",
              "dataBinding": "plot",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            }
          ]
        },
        {
          "id": "creditsSection",
          "type": "column",
          "accessibility": {
            "label": "Credits, Cast {{actors}}, Writer {{writer}}, Director {{director}}",
            "mergeDescendants": true
          },
          "style": {
            "padding": 16,
            "spacing": 10,
            "backgroundColor": "surface",
            "cornerRadius": 22
          },
          "children": [
            {
              "id": "creditsTitle",
              "type": "text",
              "text": "Credits",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 18,
                "fontWeight": "bold",
                "foregroundColor": "primaryText"
              }
            },
            {
              "id": "actors",
              "type": "text",
              "template": "Cast: {{actors}}",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            },
            {
              "id": "writer",
              "type": "text",
              "template": "Writer: {{writer}}",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            },
            {
              "id": "director",
              "type": "text",
              "template": "Director: {{director}}",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            }
          ]
        },
        {
          "id": "seasonSection",
          "type": "column",
          "accessibility": {
            "label": "Seasons section",
            "mergeDescendants": false
          },
          "style": {
            "spacing": 12
          },
          "children": [
            {
              "id": "seasonTitle",
              "type": "text",
              "text": "Seasons",
              "accessibility": {
                "role": "header"
              },
              "style": {
                "fontSize": 18,
                "fontWeight": "bold",
                "foregroundColor": "primaryText"
              }
            },
            {
              "id": "generatedSeasonList",
              "type": "generatedList",
              "countBinding": "totalSeasons",
              "accessibility": {
                "mergeDescendants": false
              },
              "style": {
                "spacing": 10
              },
              "itemLayout": {
                "id": "seasonRow",
                "type": "row",
                "accessibility": {
                  "label": "Season {{seasonNumber}}",
                  "role": "button",
                  "hint": "view season details",
                  "mergeDescendants": true
                },
                "style": {
                  "spacing": 10,
                  "padding": 14,
                  "backgroundColor": "cardBackground",
                  "cornerRadius": 18
                },
                "children": [
                  {
                    "id": "seasonBadge",
                    "type": "icon",
                    "icon": "play.tv.fill",
                    "accessibility": {
                      "importantForAccessibility": false
                    },
                    "style": {
                      "fontSize": 14,
                      "foregroundColor": "accent",
                      "frameWidth": 18,
                      "frameHeight": 18
                    }
                  },
                  {
                    "id": "seasonLabel",
                    "type": "text",
                    "template": "Season {{seasonNumber}}",
                    "accessibility": {
                      "importantForAccessibility": false
                    },
                    "style": {
                      "fontSize": 15,
                      "fontWeight": "semibold",
                      "foregroundColor": "primaryText"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}