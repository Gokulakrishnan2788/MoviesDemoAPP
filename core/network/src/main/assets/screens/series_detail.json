{
  "screenId": "series_detail",

  "bindings": {

    "title": { "source": "api", "path": "Title" },
    "year": { "source": "api", "path": "Year" },
    "genre": { "source": "api", "path": "Genre" },
    "posterURL": { "source": "api", "path": "Poster" },
    "rating": { "source": "api", "path": "imdbRating" },
    "runtime": { "source": "api", "path": "Runtime" },
    "awards": { "source": "api", "path": "Awards" },
    "plot": { "source": "api", "path": "Plot" },
    "actors": { "source": "api", "path": "Actors" },
    "writer": { "source": "api", "path": "Writer" },
    "director": { "source": "api", "path": "Director" },
    "totalSeasons": { "source": "api", "path": "totalSeasons" },


    "synopsisTitle":    { "source": "string",   "key": "series_detail.synopsis_title" },
    "creditsTitle":     { "source": "string",   "key": "series_detail.credits_title" },
    "seasonsTitle":     { "source": "string",   "key": "series_detail.seasons_title" },
    "imdbPrefix":       { "source": "string",   "key": "series_detail.imdb_prefix" },
    "runtimeLabel":     { "source": "string",   "key": "series_detail.runtime_label" },
    "awardsLabel":      { "source": "string",   "key": "series_detail.awards_label" },
    "castLabel":        { "source": "string",   "key": "series_detail.cast_label" },
    "writerLabel":      { "source": "string",   "key": "series_detail.writer_label" },
    "directorLabel":    { "source": "string",   "key": "series_detail.director_label" },
    "seasonLabel":      { "source": "string",   "key": "series_detail.season_label" },
    "seasonCountLabel": { "source": "string",   "key": "series_detail.season_count_label" },

    "headerSubtitle":   {"source": "template", "template": "{{year}} • {{genre}}"},
    "ratingText":       { "source": "template", "template": "{{imdbPrefix}} {{rating}}" },
    "runtimeText":      { "source": "template", "template": "{{runtimeLabel}} {{runtime}}" },
    "seasonCountText":  { "source": "template", "template": "{{seasonCountLabel}} {{totalSeasons}}" },
    "awardsText":       { "source": "template", "template": "{{awardsLabel}} {{awards}}" },
    "actorsText":       { "source": "template", "template": "{{castLabel}} {{actors}}" },
    "writerText":       { "source": "template", "template": "{{writerLabel}} {{writer}}" },
    "directorText":     { "source": "template", "template": "{{directorLabel}} {{director}}" }
  },

  "dataSource": {
    "type": "remote",
    "request": {
      "method": "GET",
      "url": "https://www.omdbapi.com/?i={{seriesId}}&apikey=8170cd9d",
      "headers": {},
      "queryParams": {},
      "timeout": 10
    },
    "response": {
      "type": "object",
      "fieldMapping": {
      }
    }
  },

  "type": "scroll",
  "children": [
    {
      "id": "detailColumn",
      "type": "column",
      "accessibility": {
        "mergeDescendants": false
      },
      "style": {
        "padding": 16,
        "spacing": 14,
        "backgroundColor": "screenBackground"
      },
      "children": [
        {
          "id": "backBar",
          "type": "topBar",
          "accessibility": {
            "label": "Navigate back",
            "role": "button",
            "hint": "go back"
          },
          "props": {
            "leadingIcon": "back"
          },
          "style": {
            "padding": 0,
            "paddingTop": 4,
            "paddingBottom": 0
          },
          "action": {
            "type": "back"
          }
        },
        {
          "id": "detailHeader",
          "type": "header",
          "accessibility": {
            "label": "{{title}}, {{year}}, {{genre}}",
            "role": "header",
            "mergeDescendants": true
          },
          "titleTemplate": "{{title}}",
          "subtitleTemplate": "{{headerSubtitle}}",
          "style": {
            "spacing": 4,
            "padding": 0,
            "paddingTop": 0,
            "paddingBottom": 4,
            "foregroundColor": "primaryText"
          }
        },
        {
          "id": "heroRow",
          "type": "row",
          "accessibility": {
            "label": "{{title}}, IMDb {{rating}}, Runtime {{runtime}}, Seasons {{totalSeasons}}",
            "mergeDescendants": true
          },
          "style": {
            "spacing": 16,
            "padding": 16,
            "backgroundColor": "cardBackground",
            "cornerRadius": 24
          },
          "children": [
            {
              "id": "detailPoster",
              "type": "image",
              "dataBinding": "posterURL",
              "accessibility": {
                "label": "{{title}} poster",
                "role": "image"
              },
              "style": {
                "frameWidth": 132,
                "frameHeight": 190,
                "cornerRadius": 18
              }
            },
            {
              "id": "heroMeta",
              "type": "column",
              "accessibility": {
                "mergeDescendants": true
              },
              "style": {
                "spacing": 10
              },
              "children": [
                {
                  "id": "ratingMetaRow",
                  "type": "row",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "spacing": 8
                  },
                  "children": [
                    {
                      "id": "detailRatingIcon",
                      "type": "icon",
                      "icon": "star.fill",
                      "accessibility": {
                        "importantForAccessibility": false
                      },
                      "style": {
                        "fontSize": 12,
                        "foregroundColor": "accent"
                      }
                    },
                    {
                      "id": "detailRating",
                      "type": "text",
                      "dataBinding": "ratingText",
                      "accessibility": {
                        "importantForAccessibility": false
                      },
                      "style": {
                        "fontSize": 15,
                        "fontWeight": "semibold",
                        "foregroundColor": "primaryText"
                      }
                    }
                  ]
                },
                {
                  "id": "runtime",
                  "type": "text",
                  "dataBinding": "runtimeText",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "fontSize": 14,
                    "foregroundColor": "secondaryText"
                  }
                },
                {
                  "id": "seasons",
                  "type": "text",
                  "dataBinding": "seasonCountText",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "fontSize": 14,
                    "foregroundColor": "secondaryText"
                  }
                },
                {
                  "id": "awards",
                  "type": "text",
                  "dataBinding": "awardsText",
                  "accessibility": {
                    "importantForAccessibility": false
                  },
                  "style": {
                    "fontSize": 14,
                    "foregroundColor": "secondaryText",
                    "lineLimit": 3
                  },
                  "visibility": {
                    "dataBinding": "awards",
                    "isNotEmpty": true
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "plotSection",
          "type": "column",
          "accessibility": {
            "label": "Synopsis, {{plot}}",
            "mergeDescendants": true
          },
          "style": {
            "padding": 16,
            "spacing": 10,
            "backgroundColor": "surface",
            "cornerRadius": 22
          },
          "children": [
            {
              "id": "plotTitle",
              "type": "text",
              "dataBinding": "synopsisTitle",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 18,
                "fontWeight": "bold",
                "foregroundColor": "primaryText"
              }
            },
            {
              "id": "plotText",
              "type": "text",
              "dataBinding": "plot",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            }
          ]
        },
        {
          "id": "creditsSection",
          "type": "column",
          "accessibility": {
            "label": "Credits, Cast {{actors}}, Writer {{writer}}, Director {{director}}",
            "mergeDescendants": true
          },
          "style": {
            "padding": 16,
            "spacing": 10,
            "backgroundColor": "surface",
            "cornerRadius": 22
          },
          "children": [
            {
              "id": "creditsTitle",
              "type": "text",
              "dataBinding": "creditsTitle",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 18,
                "fontWeight": "bold",
                "foregroundColor": "primaryText"
              }
            },
            {
              "id": "actors",
              "type": "text",
              "dataBinding": "actorsText",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            },
            {
              "id": "writer",
              "type": "text",
              "dataBinding": "writerText",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            },
            {
              "id": "director",
              "type": "text",
              "dataBinding": "directorText",
              "accessibility": {
                "importantForAccessibility": false
              },
              "style": {
                "fontSize": 15,
                "foregroundColor": "secondaryText"
              }
            }
          ]
        },
        {
          "id": "seasonSection",
          "type": "column",
          "accessibility": {
            "label": "Seasons section",
            "mergeDescendants": false
          },
          "style": {
            "spacing": 12
          },
          "children": [
            {
              "id": "seasonTitle",
              "type": "text",
              "dataBinding": "seasonsTitle",
              "accessibility": {
                "role": "header"
              },
              "style": {
                "fontSize": 18,
                "fontWeight": "bold",
                "foregroundColor": "primaryText"
              }
            },
            {
              "id": "generatedSeasonList",
              "type": "generatedList",
              "countBinding": "totalSeasons",
              "accessibility": {
                "mergeDescendants": false
              },
              "style": {
                "spacing": 10
              },
              "itemLayout": {
                "id": "seasonRow",
                "type": "row",
                "accessibility": {
                  "label": "Season {{seasonNumber}}",
                  "role": "button",
                  "hint": "view season details",
                  "mergeDescendants": true
                },
                "style": {
                  "spacing": 10,
                  "padding": 14,
                  "backgroundColor": "cardBackground",
                  "cornerRadius": 18
                },
                "children": [
                  {
                    "id": "seasonBadge",
                    "type": "icon",
                    "icon": "play.tv.fill",
                    "accessibility": {
                      "importantForAccessibility": false
                    },
                    "style": {
                      "fontSize": 14,
                      "foregroundColor": "accent"
                    }
                  },
                  {
                    "id": "seasonLabel",
                    "type": "text",
                    "template": "{{seasonLabel}} {{seasonNumber}}",
                    "accessibility": {
                      "importantForAccessibility": false
                    },
                    "style": {
                      "fontSize": 15,
                      "fontWeight": "semibold",
                      "foregroundColor": "primaryText"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
